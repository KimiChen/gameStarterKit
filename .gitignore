# Node
node_modules/
*.log

# 构建产物
dist/

# Cocos Creator（apps/client）——编辑器可再生目录
apps/client/library/
apps/client/temp/
apps/client/local/
apps/client/build/
apps/client/profiles/
apps/client/native/

# fairygui-cc 扩展：外壳(package.json/browser.js)提交入库，供 Creator 挂载 db://fairygui-cc；
# 运行时(`npm run fetch:fgui` 生成，fairygui.mjs 600K+ 可再生)忽略。
apps/client/extensions/fairygui-cc/runtime/

# FairyGUI 编辑器工程缓存(.objs：metas + workspace.json，编辑器可再生，勿提交)；
# .fairy/assets/settings 是源须提交，仅 .objs 忽略。无路径前缀=匹配任意 FairyGUI 工程。
.objs/

# 系统
.DS_Store

# 说明：
#  - apps/client/assets/script/shared/ 是 sync:shared 生成的，但需要提交
#    （连同 .meta，保证 uuid 稳定、新 checkout 可直接打开工程）
#  - apps/client/settings/ 需要提交（工程配置）
