# Node
node_modules/
*.log

# 构建产物
dist/

# Cocos Creator（apps/Cocos）——编辑器可再生目录
apps/Cocos/library/
apps/Cocos/temp/
apps/Cocos/local/
apps/Cocos/build/
apps/Cocos/profiles/
apps/Cocos/native/

# fairygui-cc 扩展：外壳(package.json/browser.js)提交入库，供 Creator 挂载 db://fairygui-cc；
# 运行时(`npm run fetch:fgui` 生成，fairygui.mjs 600K+ 可再生)忽略。
apps/Cocos/extensions/fairygui-cc/runtime/

# colyseus UMD：`npm run fetch:colyseus` 生成（440KB 可再生）忽略；
# .meta 提交入库（内含"导入为插件 + 全平台加载"标记，由 fetch 脚本保证）。
apps/client/src/lib/colyseus/colyseus.js
apps/Cocos/assets/src/lib/colyseus/colyseus.js

# FairyGUI 编辑器工程缓存(.objs：metas + workspace.json，编辑器可再生，勿提交)；
# .fairy/assets/settings 是源须提交，仅 .objs 忽略。无路径前缀=匹配任意 FairyGUI 工程。
.objs/

# 系统
.DS_Store

# 说明：
#  - apps/Cocos/assets/src/ 是 sync:client 从 apps/client/src 同步的生成物，但需要提交
#    （连同 .meta，保证 uuid 稳定、新 checkout 可直接打开工程）
#  - apps/Cocos/settings/ 需要提交（工程配置）
