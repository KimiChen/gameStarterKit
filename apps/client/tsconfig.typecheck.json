{
  // 独立的客户端类型检查配置（不 extends Creator 生成的 temp/，可离线/CI 跑；回流自 Arthur）。
  // 用 cc 桩（cc-stub.d.ts）替代真 cc，对 assets/script 做类型/导入路径检查。
  // 跑法：npm run typecheck:client（根 package.json；tsc 来自 server workspace 的依赖提升）。
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "types": [],
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": false,
    "baseUrl": ".",
    "paths": {}
  },
  "include": [
    "cc-stub.d.ts",
    "assets/script/designSpec.ts",
    "assets/script/lib/**/*.ts",
    "assets/script/lib/**/*.d.ts",
    "assets/script/net/**/*.ts",
    "assets/script/game/**/*.ts",
    "assets/script/shared/**/*.ts"
  ],
  "exclude": [
    // Main.ts 引 cc 运行时（组件装配/动态 import FairyGUI 视图），cc 桩下测不了；由 Creator 验。
    "assets/script/Main.ts",
    // FairyGUI 绑定层：依赖 fairygui-cc（其 d.ts 引真 cc），cc 桩下测不了；
    // 行为层（presenter）与结构契约在无头 CI 里测（npm run test:fgui）。
    "assets/script/game/ui/fgui/**",
    "**/*.meta"
  ]
}
