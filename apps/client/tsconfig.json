{
  /* Base configuration. Do not edit this field. */
  "extends": "./temp/tsconfig.cocos.json",

  /* Add your custom configuration here. */
  "compilerOptions": {
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2015", "ES2016", "ES2017"]
  },

  "include": [
    "assets/**/*.ts",
    "assets/**/*.d.ts"
  ]
}
