<?xml version="1.0" encoding="utf-8"?>
<!--
  排行榜主面板（原版 RankScene.ls，全屏模态 640x1386）。忠实原版:三国屋檐面板(rankBg1 9宫)+ 标题底(titleBg)+
  「排行榜」+ 关闭 + 总榜/省榜两 Tab(countryBtn 选中金皮 / provinceBtn 未选灰皮,代码换皮)+ 竖向虚拟列表 lst_rank +
  固定「我的名次」行 jb_playerRank。btn_close **跨包复用公司标准库 Original/CloseButton1**(src=资源id rftu3,pkg=包id k85eojd9)。
  命名即契约(presenter/RankView 按名绑):ctrl_scope / lst_rank / jb_playerRank / btn_close / btn_country / btn_province / txt_title。
  须先 loadPackage(ui/Original) 再建本组件,否则 btn_close 空占位。
-->
<component size="640,1386">
  <controller name="ctrl_scope" pages="0,总榜,1,省榜" selected="0"/>
  <displayList>
    <graph id="n0" name="img_bg" xy="0,0" size="640,1386" type="rect" lineSize="0" fillColor="#ff1a1420"/>
    <image id="n1" name="img_panel" src="pbg" fileName="art/rankBg1.png" xy="7,103" size="626,1066"/>
    <image id="n2" name="img_titleBg" src="tbg" fileName="art/titleBg.png" xy="187,116" size="265,95"/>
    <text id="n3" name="txt_title" xy="190,136" size="260,58" fontSize="46" color="#5a3a1a" align="center" vAlign="middle" bold="true" text="排行榜"/>
    <component id="n4" name="btn_close" src="rftu3" pkg="k85eojd9" fileName="CloseButton1.xml" xy="34,66" size="60,60">
      <Button/>
    </component>
    <loader id="n5" name="btn_country" xy="360,280" size="200,72" fill="scaleFree" url="ui://f5rank00tabC"/>
    <loader id="n6" name="btn_province" xy="80,280" size="200,72" fill="scaleFree" url="ui://f5rank00tabP"/>
    <text id="n7" name="txt_country" xy="360,294" size="200,44" fontSize="30" color="#ffffff" strokeColor="#000000" align="center" vAlign="middle" bold="true" text="总榜"/>
    <text id="n8" name="txt_province" xy="80,294" size="200,44" fontSize="30" color="#ffffff" strokeColor="#000000" align="center" vAlign="middle" bold="true" text="省榜"/>
    <list id="n9" name="lst_rank" xy="44,368" size="552,600" overflow="scroll" scrollBarFlags="1" scrollBar="hidden" clipSoftness="0,20" defaultItem="ui://f5rank00rkit01"/>
    <component id="n10" name="jb_playerRank" src="rkit01" fileName="RankItem.xml" xy="50,1000" size="540,117">
      <Button/>
    </component>
  </displayList>
</component>
